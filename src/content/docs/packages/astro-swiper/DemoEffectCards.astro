import { Swiper, SwiperWrapper, SwiperSlide, } from "astro-swiper";
import DemoFirstSlide from "./DemoFirstSlide.astro";
import './demo.css' // .slide-demo definition: colors, aspect-ratio, sizes,...

const title='Effect Cards'
---

<Swiper
  options={{
    effect: "cards",
    grabCursor: true,
  }}
>
  <SwiperWrapper>
    <SwiperSlide class="slide-demo slide-this-demo"> <DemoFirstSlide title={title}/> </SwiperSlide>
    <SwiperSlide class="slide-demo slide-this-demo"> <img src="/astro-dev/astro-swiper.png" alt="" /> </SwiperSlide>
    <SwiperSlide class="slide-demo slide-this-demo"> <img src="https://swiperjs.com/demos/images/nature-1.jpg" /> </SwiperSlide>
    <SwiperSlide class="slide-demo slide-this-demo"> <img src="https://swiperjs.com/demos/images/nature-2.jpg" /> </SwiperSlide>
    <SwiperSlide class="slide-demo slide-this-demo"> <img src="https://swiperjs.com/demos/images/nature-3.jpg" /> </SwiperSlide>
    <SwiperSlide class="slide-demo slide-this-demo"> <img src="https://swiperjs.com/demos/images/nature-4.jpg" /> </SwiperSlide>
  </SwiperWrapper>
</Swiper>

<style>
  .slide-this-demo:nth-child(1n) {
    background-color: rgb(206, 17, 17);
  }

  .slide-this-demo:nth-child(2n) {
    background-color: rgb(0, 140, 255);
  }

  .slide-this-demo:nth-child(3n) {
    background-color: rgb(10, 184, 111);
  }

  .slide-this-demo:nth-child(4n) {
    background-color: rgb(211, 122, 7);
  }

  .slide-this-demo:nth-child(5n) {
    background-color: rgb(118, 163, 12);
  }

  .slide-this-demo:nth-child(6n) {
    background-color: rgb(180, 10, 47);
  }

  .slide-this-demo:nth-child(7n) {
    background-color: rgb(35, 99, 19);
  }

  .slide-this-demo:nth-child(8n) {
    background-color: rgb(0, 68, 255);
  }

  .slide-this-demo:nth-child(9n) {
    background-color: rgb(218, 12, 218);
  }

  .slide-this-demo:nth-child(10n) {
    background-color: rgb(54, 94, 77);
  }
</style>