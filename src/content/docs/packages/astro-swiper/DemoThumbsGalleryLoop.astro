import { Swiper, SwiperWrapper, SwiperSlide, SwiperButtonPrev, SwiperButtonNext } from "astro-swiper";
import './slide-demo.css' // .slide-demo definition: colors, aspect-ratio, sizes,...
import DemoFirstSlide from "./DemoFirstSlide.astro";

const title="Thumbs Gallery Loop"

---

{ /*
  This demo tests how deprected thumbnail generation (prior to v2.4.0) with uniqueClass
  and linkToThumbUniqueClass props works with looped swipers, as looped swipers require
  duplicated slides and thus a different way to link the main swiper to the thumbnail swiper.
*/}
<Swiper
  uniqueClass="myswiper-thumbs-gallery-loop"
  linkToThumbUniqueClass="myswiper-thumbs-gallery-loop-thumbnail"
  useCustomElement={false}
  options={{
    loop: true,
    spaceBetween: 10,
    navigation: {
      nextEl: ".swiper-button-next",
      prevEl: ".swiper-button-prev",
    },
    astro: {
      useCustomElement: false, // set it to false to test compatibility of this prop with thumbnail
    }
  }}>
  <SwiperWrapper>
    <SwiperSlide class="slide-demo"> <DemoFirstSlide title={title}/> </SwiperSlide>
    <SwiperSlide class="slide-demo"> <img src="/astro-dev/astro-swiper.png" alt="" /> </SwiperSlide>
    <SwiperSlide class="slide-demo"> <img src="https://swiperjs.com/demos/images/nature-1.jpg" /> </SwiperSlide>
    <SwiperSlide class="slide-demo"> <img src="https://swiperjs.com/demos/images/nature-2.jpg" /> </SwiperSlide>
    <SwiperSlide class="slide-demo"> <img src="https://swiperjs.com/demos/images/nature-3.jpg" /> </SwiperSlide>
    <SwiperSlide class="slide-demo"> <img src="https://swiperjs.com/demos/images/nature-4.jpg" /> </SwiperSlide>
  </SwiperWrapper>

  <SwiperButtonPrev />
  <SwiperButtonNext />
</Swiper>


<Swiper
  uniqueClass="myswiper-thumbs-gallery-loop-thumbnail"
  options={{
    loop: true,
    spaceBetween: 10,
    slidesPerView: 4,
    freeMode: true,
    watchSlidesProgress: true,
  }}>
  <SwiperWrapper>
    <SwiperSlide class="slide-demo"> <DemoFirstSlide title={title}/> </SwiperSlide>
    <SwiperSlide class="slide-demo"> <img src="/astro-dev/astro-swiper.png" alt="" /> </SwiperSlide>
    <SwiperSlide class="slide-demo"> <img src="https://swiperjs.com/demos/images/nature-1.jpg" /> </SwiperSlide>
    <SwiperSlide class="slide-demo"> <img src="https://swiperjs.com/demos/images/nature-2.jpg" /> </SwiperSlide>
    <SwiperSlide class="slide-demo"> <img src="https://swiperjs.com/demos/images/nature-3.jpg" /> </SwiperSlide>
    <SwiperSlide class="slide-demo"> <img src="https://swiperjs.com/demos/images/nature-4.jpg" /> </SwiperSlide>
  </SwiperWrapper>
</Swiper>

<style>
  .myswiper-thumbs-gallery-loop-thumbnail .swiper-slide {
    width: 25%;
    height: 100%;
    opacity: 0.4;
  }

  .myswiper-thumbs-gallery-loop-thumbnail .swiper-slide-thumb-active {
    opacity: 1;
  }

</style>
