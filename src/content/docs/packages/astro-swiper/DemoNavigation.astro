import { Swiper, SwiperWrapper, SwiperSlide, SwiperButtonPrev, SwiperButtonNext } from "astro-swiper";
import './slide-demo.css' // .slide-demo definition: colors, aspect-ratio, sizes,...
import DemoFirstSlide from "./DemoFirstSlide.astro";

const title='Navigation'
---

<Swiper
  class="my-swiper"
  options={{
    navigation: {
      nextEl: ".swiper-button-next",
      prevEl: ".swiper-button-prev",
    },
  }}
>
  <SwiperWrapper>
    <SwiperSlide class="slide-demo"> <DemoFirstSlide title={title}/> </SwiperSlide>
    <SwiperSlide class="slide-demo"> <img src="/astro-dev/astro-swiper.png" alt="" /> </SwiperSlide>
    <SwiperSlide class="slide-demo"> Slide 3 </SwiperSlide>
    <SwiperSlide class="slide-demo"> Slide 4 </SwiperSlide>
    <SwiperSlide class="slide-demo"> Slide 5 </SwiperSlide>
    <SwiperSlide class="slide-demo"> Slide 6 </SwiperSlide>
    <SwiperSlide class="slide-demo"> Slide 7 </SwiperSlide>
    <SwiperSlide class="slide-demo"> Slide 8 </SwiperSlide>
    <SwiperSlide class="slide-demo"> Slide 9 </SwiperSlide>
  </SwiperWrapper>

  <SwiperButtonPrev />
  <SwiperButtonNext />
</Swiper>
