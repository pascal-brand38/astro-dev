import { Swiper, SwiperWrapper, SwiperSlide, SwiperButtonPrev, SwiperButtonNext, SwiperPagination } from "astro-swiper";
import './slide-demo.css' // .slide-demo definition: colors, aspect-ratio, sizes,...
import DemoFirstSlide from "./DemoFirstSlide.astro";

const title='Parallax'
---

<Swiper
  class="my-swiper swiper-parallax"
  options={{
    speed: 600,
    parallax: true,
    pagination: {
      el: ".swiper-pagination",
      clickable: true,
    },
    navigation: {
      nextEl: ".swiper-button-next",
      prevEl: ".swiper-button-prev",
    },
  }}
  style="--swiper-navigation-color: #fff; --swiper-pagination-color: #fff"
>
  <div
    class="parallax-bg"
    style="background-image: url(https://swiperjs.com/demos/images/nature-1.jpg);"
    data-swiper-parallax="-23%">
  </div>

  <SwiperWrapper>
    <SwiperSlide> <div class="slide-demo nobg"> <DemoFirstSlide title={title}/> </div> </SwiperSlide>
    <SwiperSlide> <div class="slide-demo nobg"> <img src="/astro-dev/astro-swiper.png" alt="" /> </div> </SwiperSlide>
    <SwiperSlide class="text">
        <div class="title" data-swiper-parallax="-300">Slide 3</div>
        <div class="subtitle" data-swiper-parallax="-200">Subtitle</div>
        <div class="text" data-swiper-parallax="-100">
          <p>
            Lorem ipsum dolor sit amet, consectetur adipiscing elit. Aliquam
            dictum mattis velit, sit amet faucibus felis iaculis nec. Nulla
            laoreet justo vitae porttitor porttitor. Suspendisse in sem justo.
          </p>
        </div>
    </SwiperSlide>
    <SwiperSlide class="text">
        <div class="title" data-swiper-parallax="-300">Slide 4</div>
        <div class="subtitle" data-swiper-parallax="-200">Subtitle</div>
        <div class="text" data-swiper-parallax="-100">
          <p>
            Lorem ipsum dolor sit amet, consectetur adipiscing elit. Aliquam
            dictum mattis velit, sit amet faucibus felis iaculis nec. Nulla
            laoreet justo vitae porttitor porttitor. Suspendisse in sem justo.
          </p>
        </div>
    </SwiperSlide>
    <SwiperSlide class="text">
        <div class="title" data-swiper-parallax="-300">Slide 5</div>
        <div class="subtitle" data-swiper-parallax="-200">Subtitle</div>
        <div class="text" data-swiper-parallax="-100">
          <p>
            Lorem ipsum dolor sit amet, consectetur adipiscing elit. Aliquam
            dictum mattis velit, sit amet faucibus felis iaculis nec. Nulla
            laoreet justo vitae porttitor porttitor. Suspendisse in sem justo.
          </p>
        </div>
    </SwiperSlide>
  </SwiperWrapper>

  <SwiperButtonPrev />
  <SwiperButtonNext />
  <SwiperPagination />
</Swiper>


<style>
.parallax-bg {
  position: absolute;
  left: 0;
  top: 0;
  width: 130%;
  height: 100%;
  -webkit-background-size: cover;
  background-size: cover;
  background-position: center;
}

.nobg {
  background: none;
}

.text {
  margin: 4px;
  color: black;
}
</style>
