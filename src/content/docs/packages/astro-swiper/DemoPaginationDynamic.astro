import { Swiper, SwiperWrapper, SwiperSlide, SwiperPagination } from "astro-swiper";
import './slide-demo.css' // .slide-demo definition: colors, aspect-ratio, sizes,...
import DemoFirstSlide from "./DemoFirstSlide.astro";

const title="Pagination Dynamic"
---

<Swiper
  class="my-swiper"
  options={{
    pagination: {
      el: ".swiper-pagination",
      dynamicBullets: true,
    },
  }}
>
  <SwiperWrapper>
    <SwiperSlide> <div class="slide-demo"> <DemoFirstSlide title={title}/> </div> </SwiperSlide>
    <SwiperSlide> <div class="slide-demo"> <img src="/astro-dev/astro-swiper.png" alt="" /> </div> </SwiperSlide>
    <SwiperSlide> <div class="slide-demo"> Slide 3 </div> </SwiperSlide>
    <SwiperSlide> <div class="slide-demo"> Slide 4 </div> </SwiperSlide>
    <SwiperSlide> <div class="slide-demo"> Slide 5 </div> </SwiperSlide>
    <SwiperSlide> <div class="slide-demo"> Slide 6 </div> </SwiperSlide>
    <SwiperSlide> <div class="slide-demo"> Slide 7 </div> </SwiperSlide>
    <SwiperSlide> <div class="slide-demo"> Slide 8 </div> </SwiperSlide>
    <SwiperSlide> <div class="slide-demo"> Slide 9 </div> </SwiperSlide>
  </SwiperWrapper>

  <SwiperPagination />
</Swiper>
