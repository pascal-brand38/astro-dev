import { Swiper, SwiperWrapper, SwiperSlide, SwiperButtonPrev, SwiperButtonNext, SwiperPagination } from "astro-swiper";
import './slide-demo.css' // .slide-demo definition: colors, aspect-ratio, sizes,...
import DemoFirstSlide from "./DemoFirstSlide.astro";

const title='History'
---

<Swiper
  class="my-swiper"
  options={{
    spaceBetween: 50,
    slidesPerView: 1,
    navigation: {
      nextEl: ".swiper-button-next",
      prevEl: ".swiper-button-prev",
    },
    pagination: {
      el: ".swiper-pagination",
    },
    history: {
      key: "slide",
    },
  }}
>
  <SwiperWrapper>
    <SwiperSlide class="slide-demo" data-history="1"> <DemoFirstSlide title={title}/> </SwiperSlide>
    <SwiperSlide class="slide-demo" data-history="2"> <img src="/astro-dev/astro-swiper.png" alt="" /> </SwiperSlide>
    <SwiperSlide class="slide-demo" data-history="3"> Slide 3 </SwiperSlide>
    <SwiperSlide class="slide-demo" data-history="4"> Slide 4 </SwiperSlide>
    <SwiperSlide class="slide-demo" data-history="5"> Slide 5 </SwiperSlide>
    <SwiperSlide class="slide-demo" data-history="6"> Slide 6 </SwiperSlide>
    <SwiperSlide class="slide-demo" data-history="7"> Slide 7 </SwiperSlide>
    <SwiperSlide class="slide-demo" data-history="8"> Slide 8 </SwiperSlide>
    <SwiperSlide class="slide-demo" data-history="9"> Slide 9 </SwiperSlide>
  </SwiperWrapper>

  <SwiperButtonPrev />
  <SwiperButtonNext />
  <SwiperPagination />
</Swiper>
