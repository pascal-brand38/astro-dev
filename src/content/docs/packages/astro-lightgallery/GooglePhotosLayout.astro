import { LightGallery } from "astro-lightgallery";
---

<LightGallery
  layout={{
    type: 'google-photos',
    imgs: [
      // srcs is provided via layout.srcs, so imgs will be rendered using <Image>
      // the images are in /src repo
      { src: "/src/images/astro-lightgallery/img01.jpg", },
      { src: "/src/images/astro-lightgallery/img02.jpg", position: '50% 100%' },
      { src: "/src/images/astro-lightgallery/img03.jpg", },
      { src: "/src/images/astro-lightgallery/img04.jpg", },
      { src: "/src/images/astro-lightgallery/img05.jpg", },
      { src: "/src/images/astro-lightgallery/img06.jpg", },
      { src: "/src/images/astro-lightgallery/img07.jpg", },
      { src: "/src/images/astro-lightgallery/img08.jpg", },
      { src: "/src/images/astro-lightgallery/img09.jpg", },
    ],
    srcs: import.meta.glob<{ default: ImageMetadata }>('/src/images/**/*.{jpg,webp}'),
    googlePhotos: {
      height: '45vw',  // default height of the gallery
      maxHeight: '45vw',
      breakpoints: {
        320: {  // on screen larger than 320px
          height: '30vw',
          maxHeight: '30vw',
        },
        720: {  // on screen larger than 720px
          height: '200px',
          maxHeight: '200px',
        },
      },
    },
  }}
  options={{
    thumbnail: true,
  }}
/>
