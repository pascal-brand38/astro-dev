      { src: "/astro-dev/images/astro-lightgallery/img02-public.jpg", },
      { src: "/astro-dev/images/astro-lightgallery/img03-public.jpg", },
      { src: "/astro-dev/images/astro-lightgallery/img04-public.jpg", },
      { src: "/astro-dev/images/astro-lightgallery/img05-public.jpg", },
      { src: "/astro-dev/images/astro-lightgallery/img06-public.jpg", },
      { src: "/astro-dev/images/astro-lightgallery/img07-public.jpg", },
      { src: "/astro-dev/images/astro-lightgallery/img08-public.jpg", },
      { src: "/astro-dev/images/astro-lightgallery/img09-public.jpg", },
    ],
  }}
  options={{
    thumbnail: true,
  }}
/>
